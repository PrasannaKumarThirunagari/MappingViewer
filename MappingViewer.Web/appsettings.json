{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ExcelSettings": {
    "FolderPath": "Data",
    "TableDetection": {
      "HeaderBackgroundColors": [ "BFBFBF", "A6A6A6", "808080", "D9D9D9", "C0C0C0" ],
      "DetectHeaderByBackgroundColor": true,
      "DetectHeaderByBoldFont": false,
      "DetectHeaderByColumnLabels": true,
      "HeaderColumnLabels": [ "Data Type (Object)", "FHIR Data Type" ],
      "HeaderColumnLabelsAreRegexPatterns": false,
      "RequireAllHeaderColumnLabels": false,
      "HeaderColumnLabelMinimumMatches": 1,
      "HeaderMinimumFilledCells": 2,

      "TableTitleBackgroundColors": [],
      "DetectTableTitleBeforeHeader": true,
      "DetectTableTitleByBackgroundColor": true,
      "TableTitleMinimumFilledCells": 1,
      "TableTitleMaximumFilledCells": 1,

      "DataRowMinimumFilledCells": 2,

      "NeutralBackgroundColors": [ "FFFFFF", "FFFFFFFF", "000000", "FF000000" ]
    }
  }
}
