@model MappingViewer.Web.Models.WorkbookData
@using MappingViewer.Web.Services
@inject IExcelReaderService ExcelReader
@{
    ViewData["Title"] = Model.FileName;
    var workbookFiles = ViewBag.WorkbookFiles as List<string> ?? new List<string>();
    var currentFile = ViewBag.CurrentFile as string ?? Model.FileName;

    string CellStyle(MappingViewer.Web.Models.CellData c)
    {
        var parts = new List<string>();
        if (!string.IsNullOrEmpty(c.BackgroundColor)
            && ExcelReaderService.IsValidHexColor(c.BackgroundColor)
            && !ExcelReader.IsNeutralDisplayColor(c.BackgroundColor))
            parts.Add($"background-color:#{c.BackgroundColor}");
        if (ExcelReaderService.IsValidHexColor(c.FontColor ?? ""))
            parts.Add($"color:#{c.FontColor}");
        if (c.Bold) parts.Add("font-weight:600");
        if (c.Indent > 0)
            parts.Add($"padding-left:{10 + c.Indent * 3}px");
        var align = c.HorizontalAlignment?.ToLowerInvariant() switch
        {
            "center" => "center",
            "right" => "right",
            "left" or "general" => "left",
            _ => null
        };
        if (align != null) parts.Add($"text-align:{align}");
        return parts.Count == 0 ? "" : string.Join(";", parts);
    }

    string CellDisplayClass(MappingViewer.Web.Models.CellData c)
    {
        return (c.WrapText || c.Value.Contains('\n') || c.Value.Contains('\r'))
            ? "cell-display cell-display--wrap"
            : "cell-display";
    }

    // Excel-style column letter for index 1 = A, 2 = B, ..., 26 = Z, 27 = AA, ...
    string ExcelColumnLetter(int oneBased)
    {
        if (oneBased < 1) return string.Empty;
        var sb = new System.Text.StringBuilder();
        int n = oneBased;
        while (n > 0)
        {
            int rem = (n - 1) % 26;
            sb.Insert(0, (char)('A' + rem));
            n = (n - 1) / 26;
        }
        return sb.ToString();
    }

    const int LongCellThreshold = 150;
}

<section class="viewer-page flex flex-col min-h-0 flex-1 w-full bg-slate-50">
    @if (Model.Sheets.Count == 0)
    {
        <p class="empty viewer-page__empty m-6">This workbook contains no sheets.</p>
    }
    else
    {
        <div id="viewerBody" class="viewer-body flex flex-1 min-h-0 min-w-0">
            <aside id="viewerSidebar" class="viewer-sidebar w-56 shrink-0 flex flex-col bg-slate-50 min-h-0" aria-label="Sheets">
                <div class="viewer-sidebar__header px-4 pt-5 pb-3">
                    <div class="flex items-center justify-between gap-2 mb-3">
                        <span class="text-xs font-semibold uppercase tracking-wider text-slate-500">Sheets</span>
                        <span class="text-xs text-slate-400">@Model.Sheets.Count</span>
                    </div>
                    <label class="visually-hidden" for="sheetSearch">Search sheets</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 flex items-center pl-2.5 text-slate-400 pointer-events-none" aria-hidden="true">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4">
                                <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 1 0 3.473 9.768l3.13 3.129a.75.75 0 1 0 1.06-1.06l-3.129-3.13A5.5 5.5 0 0 0 9 3.5ZM5 9a4 4 0 1 1 8 0 4 4 0 0 1-8 0Z" clip-rule="evenodd" />
                            </svg>
                        </span>
                        <input id="sheetSearch" type="search"
                               class="viewer-sidebar__search w-full pl-8 pr-2 py-2 text-sm rounded-lg border border-slate-200 bg-white text-slate-800 placeholder:text-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                               placeholder="Search sheets…" autocomplete="off" />
                    </div>
                </div>
                <nav class="viewer-sidebar__list flex-1 min-h-0 overflow-y-auto px-3 py-2 flex flex-col gap-0.5"
                     role="tablist" aria-label="Workbook sheets">
                    @for (var i = 0; i < Model.Sheets.Count; i++)
                    {
                        var sheet = Model.Sheets[i];
                        var active = i == 0 ? "sheet-link--active" : "";
                        <button type="button" role="tab"
                                class="sheet-link @active w-full px-2 py-2 rounded-md text-sm text-left font-medium transition-colors text-slate-600 hover:text-slate-800"
                                data-sheet-target="sheet-@i"
                                data-sheet-name="@sheet.Name"
                                aria-selected="@(i == 0 ? "true" : "false")"
                                title="@sheet.Name">
                            <span class="sheet-link__name truncate block">@sheet.Name</span>
                        </button>
                    }
                </nav>
                <p id="sheetSearchEmpty" class="viewer-sidebar__empty is-hidden px-4 py-3 text-center text-xs text-slate-500">No sheets match.</p>
                <div class="viewer-sidebar__footer shrink-0 px-4 py-4 border-t border-slate-200 mt-auto">
                    <a class="viewer-sidebar__brand inline-flex items-center gap-2.5 text-slate-800 font-semibold text-sm hover:no-underline"
                       asp-controller="Home" asp-action="Index" title="Back to workbooks">
                        <span class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-blue-600 text-white text-sm font-bold shadow-sm">M</span>
                        <span>Mapping Viewer</span>
                    </a>
                </div>
            </aside>

            <div class="viewer-workspace flex-1 min-w-0 min-h-0 flex flex-col p-3 md:p-4">
            <div class="viewer-content-card flex flex-col flex-1 min-h-0 bg-white rounded-xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="viewer-toolbar flex items-center gap-2 sm:gap-3 flex-nowrap px-4 py-3 border-b border-slate-100 shrink-0">
                <button id="toggleSidebar" type="button"
                        class="sidebar-toggle shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-lg border border-slate-200 bg-white text-slate-600 hover:text-blue-600 hover:border-blue-300 transition-colors"
                        aria-controls="viewerSidebar"
                        aria-expanded="true"
                        title="Hide sheet list">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5" aria-hidden="true">
                        <path fill-rule="evenodd" d="M2 4.75A.75.75 0 0 1 2.75 4h14.5a.75.75 0 0 1 0 1.5H2.75A.75.75 0 0 1 2 4.75Zm0 5.5a.75.75 0 0 1 .75-.75h14.5a.75.75 0 0 1 0 1.5H2.75a.75.75 0 0 1-.75-.75ZM2.75 14a.75.75 0 0 0 0 1.5h14.5a.75.75 0 0 0 0-1.5H2.75Z" clip-rule="evenodd" />
                    </svg>
                    <span class="visually-hidden">Toggle sheet list</span>
                </button>
                <h2 class="viewer-toolbar__title text-base font-semibold text-slate-800 truncate mr-2">@Model.FileName</h2>
                <label class="visually-hidden" for="workbookSelect">Workbook</label>
                <select id="workbookSelect"
                        class="workbook-select max-w-[200px] min-w-[120px] shrink-0 px-2.5 py-1.5 text-sm rounded-lg border border-slate-200 bg-white text-slate-800 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                        aria-label="Select workbook">
                    @foreach (var f in workbookFiles)
                    {
                        if (string.Equals(f, currentFile, StringComparison.OrdinalIgnoreCase))
                        {
                            <option value="@f" selected="selected">@f</option>
                        }
                        else
                        {
                            <option value="@f">@f</option>
                        }
                    }
                </select>
                <div class="flex-1 min-w-2"></div>
                <label class="description-toggle inline-flex items-center gap-1.5 shrink-0 text-xs text-slate-500 cursor-pointer select-none whitespace-nowrap">
                    <input id="showDescription" type="checkbox" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                    <span>Show notes</span>
                </label>
                <input id="globalSearch"
                       class="viewer-toolbar__search w-full max-w-xs min-w-[120px] px-2.5 py-1.5 text-sm rounded-lg border border-slate-200 bg-white placeholder:text-slate-400 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                       type="search"
                       placeholder="Filter all columns…" autocomplete="off" />
                <label class="case-toggle inline-flex items-center gap-1.5 shrink-0 text-xs text-slate-500 cursor-pointer select-none whitespace-nowrap">
                    <input id="caseSensitive" type="checkbox" class="rounded border-slate-300 text-blue-600 focus:ring-blue-500" />
                    <span>Case sensitive</span>
                </label>
                <button id="reloadWorkbook" type="button"
                        class="btn-tool viewer-toolbar__reload inline-flex items-center justify-center w-8 h-8 shrink-0 rounded-full bg-blue-600 text-white border-0 hover:bg-blue-700 transition-colors shadow-sm"
                        title="Reload workbook from disk">
                    <span class="btn-tool__icon text-base leading-none" aria-hidden="true">↻</span>
                    <span class="visually-hidden">Reload</span>
                </button>
            </div>
            @for (var i = 0; i < Model.Sheets.Count; i++)
            {
                var sheet = Model.Sheets[i];
                var hidden = i == 0 ? "" : "is-hidden";

                <div id="sheet-@i" class="sheet-panel @hidden" role="tabpanel"
                     data-sheet-name="@sheet.Name"
                     data-sheet-mode="@(sheet.HasDetectedTables ? "tables" : "raw")">
                    @if (!sheet.HasDetectedTables && sheet.RawSheetRows.Count == 0)
                    {
                        <p class="empty">This sheet is empty.</p>
                    }
                    else if (!sheet.HasDetectedTables && sheet.RawSheetRows.Count > 0)
                    {
                        var rawMaxCols = sheet.RawDisplayColumnCount;
                        @* No structured table detected — show full sheet as one filterable grid. *@
                        <div class="tables-stack">
                            <div class="table-block raw-sheet-block" data-table-index="0">
                                <div class="table-block__bar">
                                    <span class="table-block__title-text">@sheet.Name</span>
                                    <span class="raw-sheet-block__hint">No tables detected — showing sheet content</span>
                                    <div class="table-block__actions">
                                        <button type="button" class="btn-tool" data-expand-table title="Expand">
                                            <span class="btn-tool__icon" aria-hidden="true">⛶</span>
                                            <span>Expand</span>
                                        </button>
                                        <button type="button" class="btn-tool" data-reset-columns title="Reset column order and width">
                                            <span class="btn-tool__icon" aria-hidden="true">↺</span>
                                            <span>Reset cols</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="table-scroll">
                                    <table class="data-table data-table--raw" id="rawtable-@i">
                                        <colgroup>
                                            @for (var c = 0; c < rawMaxCols; c++)
                                            {
                                                <col data-col-idx="@c" />
                                            }
                                        </colgroup>
                                        <thead>
                                            <tr class="data-table__headers">
                                                @for (var c = 0; c < rawMaxCols; c++)
                                                {
                                                    var letter = ExcelColumnLetter(c + 1);
                                                    <th class="data-table__th"
                                                        data-col-idx="@c"
                                                        draggable="true"
                                                        data-full-text="@letter">
                                                        <span class="th-label">@letter</span>
                                                        <span class="col-resize-handle" title="Resize column"></span>
                                                    </th>
                                                }
                                            </tr>
                                            <tr class="data-table__filters">
                                                @for (var c = 0; c < rawMaxCols; c++)
                                                {
                                                    <th class="data-table__filter-th" data-col-idx="@c">
                                                        <input type="search" class="col-filter"
                                                               data-col="@c"
                                                               placeholder="Filter…"
                                                               autocomplete="off" />
                                                    </th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @{ var rawRowIndex = 0; }
                                            @foreach (var row in sheet.RawSheetRows)
                                            {
                                                <tr class="data-row" data-row-index="@rawRowIndex">
                                                    @for (var c = 0; c < rawMaxCols; c++)
                                                    {
                                                        var cell = c < row.Count ? row[c] : new MappingViewer.Web.Models.CellData();
                                                        var isLongCell = cell.Value.Length > LongCellThreshold;
                                                        <td class="@CellDisplayClass(cell)@(isLongCell ? " cell-display--long" : "")"
                                                            data-col-idx="@c"
                                                            style="@CellStyle(cell)"
                                                            data-full-text="@cell.Value">
                                                            @if (isLongCell)
                                                            {
                                                                <span class="cell-preview">@(cell.Value.Substring(0, LongCellThreshold))…</span>
                                                                <button type="button" class="cell-details-link">View details</button>
                                                            }
                                                            else
                                                            {
                                                                @cell.Value
                                                            }
                                                        </td>
                                                    }
                                                </tr>
                                                rawRowIndex++;
                                            }
                                        </tbody>
                                        <tfoot>
                                            <tr>
                                                <td colspan="@rawMaxCols" class="data-table__footer">
                                                        Showing <span class="row-visible">@sheet.RawSheetRows.Count</span>
                                                        of <span class="row-total">@sheet.RawSheetRows.Count</span> rows
                                                </td>
                                            </tr>
                                        </tfoot>
                                    </table>
                                </div>
                            </div>
                        </div>
                    }
                    else if (sheet.HasDetectedTables)
                    {
                    <div class="tables-stack">
                        @for (var bi = 0; bi < sheet.Blocks.Count; bi++)
                        {
                            var block = sheet.Blocks[bi];
                            @if (block.FreeformRows != null && block.FreeformRows.Count > 0)
                            {
                                // Collapse the few text rows between tables into one UI row.
                                var noteSegments = block.FreeformRows
                                    .Select(r => string.Join(" · ",
                                        r.Where(c => !string.IsNullOrWhiteSpace(c.Value))
                                         .Select(c => c.Value.Trim())))
                                    .Where(s => !string.IsNullOrWhiteSpace(s))
                                    .ToList();
                                var noteText = string.Join("  •  ", noteSegments);
                                var noteFullText = string.Join("\n", noteSegments);
                                @if (noteSegments.Count > 0)
                                {
                                    @* Between-table notes always show — they're inline context for the
                                       table that follows. The "Show description" toggle controls only the
                                       sheet-level description block above the first table. *@
                                    <div class="between-tables-row-wrap" data-between-note>
                                        <table class="between-tables-table w-full border-collapse">
                                            <tbody>
                                                <tr>
                                                    <td class="between-tables-table__cell cell-display"
                                                        title="@noteFullText"
                                                        data-full-text="@noteFullText">@noteText</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            }
                            @if (block.Table != null)
                            {
                                var table = block.Table;
                                <div class="table-block" data-table-index="@bi">
                                    @{
                                        var titleStyle = "";
                                        if (!string.IsNullOrEmpty(table.Title))
                                        {
                                            if (!string.IsNullOrEmpty(table.TitleBackgroundColor)
                                                && ExcelReaderService.IsValidHexColor(table.TitleBackgroundColor)
                                                && !ExcelReader.IsNeutralDisplayColor(table.TitleBackgroundColor))
                                                titleStyle += $"background-color:#{table.TitleBackgroundColor};";
                                            if (ExcelReaderService.IsValidHexColor(table.TitleFontColor ?? ""))
                                                titleStyle += $"color:#{table.TitleFontColor};";
                                        }
                                    }
                                    <div class="table-block__bar" style="@titleStyle">
                                        <span class="table-block__title-text">@(table.Title ?? "Table")</span>
                                        <div class="table-block__actions">
                                            <button type="button" class="btn-tool" data-expand-table title="Expand table">
                                                <span class="btn-tool__icon" aria-hidden="true">⛶</span>
                                                <span>Expand</span>
                                            </button>
                                            <button type="button" class="btn-tool" data-reset-columns title="Reset column order and width">
                                                <span class="btn-tool__icon" aria-hidden="true">↺</span>
                                                <span>Reset cols</span>
                                            </button>
                                        </div>
                                    </div>

                                    <div class="table-scroll">
                                        <table class="data-table" id="table-@i-@bi">
                                            <colgroup>
                                                @for (var c = 0; c < table.Headers.Count; c++)
                                                {
                                                    <col data-col-idx="@c" />
                                                }
                                            </colgroup>
                                            <thead>
                                                <tr class="data-table__headers">
                                                    @for (var c = 0; c < table.Headers.Count; c++)
                                                    {
                                                        var h = table.Headers[c];
                                                        <th class="data-table__th"
                                                            data-col-idx="@c"
                                                            draggable="true"
                                                            style="@CellStyle(h)"
                                                            data-full-text="@h.Value">
                                                            <span class="th-label">@h.Value</span>
                                                            <span class="col-resize-handle" title="Resize column"></span>
                                                        </th>
                                                    }
                                                </tr>
                                                <tr class="data-table__filters">
                                                    @for (var c = 0; c < table.Headers.Count; c++)
                                                    {
                                                        <th class="data-table__filter-th" data-col-idx="@c">
                                                            <input type="search" class="col-filter"
                                                                   data-col="@c"
                                                                   placeholder="Filter…"
                                                                   autocomplete="off" />
                                                        </th>
                                                    }
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @{ var rowIndex = 0; }
                                                @foreach (var row in table.Rows)
                                                {
                                                    <tr class="data-row" data-row-index="@rowIndex">
                                                        @for (var c = 0; c < table.Headers.Count; c++)
                                                        {
                                                            var cell = c < row.Count ? row[c] : new MappingViewer.Web.Models.CellData();
                                                            var isLongCell = cell.Value.Length > LongCellThreshold;
                                                            <td class="@CellDisplayClass(cell)@(isLongCell ? " cell-display--long" : "")"
                                                                data-col-idx="@c"
                                                                style="@CellStyle(cell)"
                                                                data-full-text="@cell.Value">
                                                                @if (isLongCell)
                                                                {
                                                                    <span class="cell-preview">@(cell.Value.Substring(0, LongCellThreshold))…</span>
                                                                    <button type="button" class="cell-details-link">View details</button>
                                                                }
                                                                else
                                                                {
                                                                    @cell.Value
                                                                }
                                                            </td>
                                                        }
                                                    </tr>
                                                    rowIndex++;
                                                }
                                            </tbody>
                                            <tfoot>
                                                <tr>
                                                    <td colspan="@table.Headers.Count" class="data-table__footer">
                                                        Showing <span class="row-visible">@table.Rows.Count</span>
                                                        of <span class="row-total">@table.Rows.Count</span> rows
                                                    </td>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @if (sheet.Description.Count > 0)
                    {
                        <div class="freeform-panel" data-freeform-panel>
                            <div class="description-block">
                                <div class="description-block__label">Description</div>
                                <table class="description-table">
                                    <tbody>
                                        @foreach (var row in sheet.Description)
                                        {
                                            <tr>
                                                @foreach (var cell in row)
                                                {
                                                    <td class="@CellDisplayClass(cell)"
                                                        style="@CellStyle(cell)"
                                                        data-full-text="@cell.Value">@cell.Value</td>
                                                }
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    }
                    else
                    {
                        <p class="empty">This sheet has no displayable content.</p>
                    }
                </div>
            }
            </div>
            </div>
        </div>
    }
</section>

<div id="tableExpandModal" class="table-expand-modal is-hidden" role="dialog" aria-modal="true" aria-labelledby="tableExpandTitle">
    <div class="table-expand-modal__backdrop" data-close-table-expand></div>
    <div class="table-expand-modal__panel">
        <div class="table-expand-modal__header">
            <h2 id="tableExpandTitle" class="table-expand-modal__title">Table</h2>
            <div class="table-expand-modal__controls">
                <input id="tableExpandSearch" class="table-expand-modal__search" type="search"
                       placeholder="Search in this table…" autocomplete="off" />
                <label class="case-toggle table-expand-modal__case">
                    <input id="tableExpandCase" type="checkbox" />
                    <span>Case sensitive</span>
                </label>
                <button type="button" class="btn-tool btn-tool--icon" data-close-table-expand aria-label="Close">&times;</button>
            </div>
        </div>
        <div id="tableExpandBody" class="table-expand-modal__body"></div>
    </div>
</div>

<div id="cellPopup" class="cell-popup is-hidden" role="dialog" aria-modal="true" aria-labelledby="cellPopupTitle">
    <div class="cell-popup__backdrop" data-close-popup></div>
    <div class="cell-popup__panel">
        <div class="cell-popup__header">
            <h2 id="cellPopupTitle" class="cell-popup__title">Cell details</h2>
            <button type="button" class="cell-popup__close" data-close-popup aria-label="Close">&times;</button>
        </div>
        <pre id="cellPopupContent" class="cell-popup__content"></pre>
    </div>
</div>

@section Scripts {
    <script src="~/js/table-grid.js" asp-append-version="true"></script>
    <script src="~/js/viewer.js" asp-append-version="true"></script>
}
