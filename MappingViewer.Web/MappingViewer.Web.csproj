<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>MappingViewer.Web</RootNamespace>
    <AssemblyName>MappingViewer.Web</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="EPPlus" Version="7.4.2" />
  </ItemGroup>

  <ItemGroup>
    <!-- Ship the sample workbooks with the build output so the app works out of the box. -->
    <Content Include="Data\**\*.xlsx" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
